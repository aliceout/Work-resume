---
import Band from "./Band.astro";
import Icon from "./Icon.astro";
import ThemeTags from "./ThemeTags.astro";

interface Theme {
  id: string;
  name: string;
  colorDeep: string;
  colorSoft: string;
}

interface Props {
  date?: string;
  title?: string;
  org?: string;
  loc?: string;
  desc?: string;
  bullets?: string[];
  side?: string;
  themes?: string[];
  themesMeta?: Record<string, Theme>;
  logo?: string;
}

const {
  date,
  title,
  org,
  loc,
  desc,
  bullets,
  side,
  themes,
  themesMeta,
  logo,
} = Astro.props;

const parseDate = (d?: string) => {
  if (!d) return { yr: "", rest: "" };
  const yearsMatch = d.match(/(\d{4})(?:\s*[-–]\s*(\d{4}))?/);
  if (!yearsMatch) return { yr: "", rest: d.trim() };

  const yr = yearsMatch[2]
    ? `${yearsMatch[1]} - ${yearsMatch[2]}`
    : yearsMatch[1];

  const rest = d
    .replace(yearsMatch[0], "")
    .trim()
    .replace(/^[-–·\s]+/, "")
    .replace(/[-–·\s]+$/, "")
    .replace(/\s+[-–·]\s+/g, " · ")
    .trim();

  return { yr, rest };
};

const renderInline = (text?: string) => {
  if (!text) return "";
  // Replace **bold** with <strong> and \n with <br/>
  return text
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\n/g, "<br/>");
};

const { yr, rest } = parseDate(date);
---

<Band>
  <div class="proto-entry">
    <div class="proto-date">
      <div class="proto-yr">{yr}</div>
      {rest && <div>{rest}</div>}
    </div>
    <div class="proto-body">
      <h3>{title}</h3>
      {(org || loc) && (
        <div class="proto-org-line">
          {org && <span class="proto-org">{org}</span>}
          {loc && <span class="proto-loc">◉ {loc}</span>}
        </div>
      )}
      {desc && (
        <p class="proto-desc" set:html={renderInline(desc)} />
      )}
      {bullets && bullets.length > 0 && (
        <ul>
          {bullets.map((b) => (
            <li set:html={renderInline(b)} />
          ))}
        </ul>
      )}
      <ThemeTags themes={themes} themesMeta={themesMeta} />
    </div>
    {(side || logo) && (
      <div class="proto-tag-right">
        {side && (
          <div class="proto-tag-loc">
            <Icon name="pin" size={11} />
            <span>{side}</span>
          </div>
        )}
        {logo && (
          <img
            src={logo}
            alt=""
            class="proto-tag-logo"
            loading="lazy"
            width="128"
            height="128"
          />
        )}
      </div>
    )}
  </div>
</Band>
