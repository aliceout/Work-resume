---
interface Theme {
  id: string;
  name: string;
  colorDeep: string;
  colorSoft: string;
}

interface Props {
  themes?: string[];
  themesMeta?: Record<string, Theme>;
  lang?: string;
}

const { themes = [], themesMeta = {}, lang = "fr" } = Astro.props;
const visible = themes
  .map((id) => themesMeta[id])
  .filter((t): t is Theme => !!t);
---

{visible.length > 0 && (
  <div class="proto-theme-tags">
    {visible.map((t) => (
      <a
        href={`/${lang}/themes/${t.id}`}
        class="proto-theme-tag"
        style={`--c: ${t.colorDeep}; --c-soft: ${t.colorSoft};`}
      >
        <span class="proto-dot" />
        {t.name}
      </a>
    ))}
  </div>
)}
