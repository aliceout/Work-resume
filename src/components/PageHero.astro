---
import HeroBand from "./HeroBand.astro";
import { useTranslation } from "../utils/i18n.js";

interface Props {
  section: string;
  namespace: string;
  ledeOverride?: string;
  lang?: string;
}

const { section, namespace, ledeOverride, lang } = Astro.props;
const { t } = useTranslation("pages", lang ?? (Astro.params.lang as string));
---

<HeroBand
  section={section}
  label={t(`${namespace}.hero.label`)}
  title={t(`${namespace}.hero.title`)}
  em={t(`${namespace}.hero.em`)}
  lede={ledeOverride ?? t(`${namespace}.hero.lede`)}
/>
