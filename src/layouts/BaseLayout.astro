---
// Self-hosted fonts (variable, weight axis only; Fraunces italic only)
import "@fontsource-variable/inter/wght.css";
import "@fontsource-variable/inter-tight/wght.css";
import "@fontsource-variable/fraunces/wght-italic.css";
import "@fontsource-variable/jetbrains-mono/wght.css";
// woff2 URLs for preloading the above-the-fold hero fonts
import interTightWoff2 from "@fontsource-variable/inter-tight/files/inter-tight-latin-wght-normal.woff2?url";
import frauncesItalicWoff2 from "@fontsource-variable/fraunces/files/fraunces-latin-wght-italic.woff2?url";

import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { getImage } from "astro:assets";
import { useTranslation } from "../utils/i18n.js";
import profilePhoto from "../assets/profile.jpg";

interface Props {
  lang?: string;
  title?: string;
  description?: string;
  path?: string;
  jobTitle?: string;
  withPersonSchema?: boolean;
}

const {
  lang = "fr",
  title,
  description = "",
  path = "/",
  jobTitle = "",
  withPersonSchema = false,
} = Astro.props;

const { t } = useTranslation("common", lang);
const personName = t("name");
const resolvedTitle = title || personName;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "";
const canonical = `${siteUrl}${path}`;

// Social card (1200×630) for og:image / twitter:image — static asset in /public
const ogCard = `${siteUrl}/og-image.png`;

// Square portrait (1200×1200) for Person.image (Knowledge Panel)
const portraitAsset = await getImage({
  src: profilePhoto,
  width: 1200,
  height: 1200,
  format: "jpg",
  quality: 86,
});
const portrait = `${siteUrl}${portraitAsset.src}`;

const ogLocale = lang === "en" ? "en_US" : "fr_FR";
const ogLocaleAlternate = lang === "en" ? "fr_FR" : "en_US";

// Site Name signal for Google (rendered on every page; Google reads
// it preferentially on the homepage when computing the site name).
// Trailing slash on URL matches what Google considers a canonical
// home; alternateName gives Google a backup label.
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: personName,
  alternateName: t("firstName"),
  url: `${siteUrl}/`,
  inLanguage: lang === "en" ? "en" : "fr",
};

const personSchema = withPersonSchema
  ? {
      "@context": "https://schema.org",
      "@type": "Person",
      name: personName,
      jobTitle,
      description,
      url: canonical,
      image: portrait,
      sameAs: [
        t("linkedinUrl"),
        t("githubUrl"),
        t("carnetUrl"),
      ].filter((u) => typeof u === "string" && u.startsWith("http")),
      knowsAbout: [
        "Solidarité internationale",
        "Coordination humanitaire",
        "Politiques migratoires",
        "Études de genre",
        "Développement web",
      ],
    }
  : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{resolvedTitle}</title>
    {description && <meta name="description" content={description} />}
    {/* application-name = additional site name signal for Google */}
    <meta name="application-name" content={personName} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph (LinkedIn, Slack, Bluesky, Discord…) */}
    <meta property="og:site_name" content={personName} />
    <meta property="og:title" content={resolvedTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogCard} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogCard} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    {/* Preload above-the-fold hero fonts (title + italic em) */}
    <link
      rel="preload"
      href={interTightWoff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={frauncesItalicWoff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <ClientRouter />

    {/* WebSite JSON-LD — signals the site name to Google */}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />

    {
      personSchema && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(personSchema)}
        />
      )
    }

    <script is:inline>
      (function () {
        const applyTheme = () => {
          try {
            const stored = localStorage.getItem("theme");
            const prefersDark =
              window.matchMedia &&
              window.matchMedia("(prefers-color-scheme: dark)").matches;
            const theme = stored || (prefersDark ? "dark" : "light");
            document.documentElement.setAttribute("data-theme", theme);
          } catch (_) {
            /* no-op */
          }
        };
        applyTheme();
        // Re-apply after each ClientRouter (View Transitions) navigation —
        // Astro may reset <html data-theme> when swapping documents.
        if (!window.__themeApplyBound) {
          window.__themeApplyBound = true;
          document.addEventListener("astro:after-swap", applyTheme);
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
